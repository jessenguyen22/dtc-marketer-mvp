# Skillor environment variables
# Copy to .env.local for local dev. NEVER commit .env.local.

# ── PayPal (Smart Buttons) ─────────────────────────────────────
# sandbox | live
PAYPAL_MODE=sandbox
# Public client ID (safe to expose to browser)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# Server-only secret — required for OAuth2 token + capture
PAYPAL_CLIENT_SECRET=

# ── JWT signing (download tokens, custom_id payload) ──────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Resend (transactional email) ──────────────────────────────
RESEND_API_KEY=
# Use onboarding@resend.dev until you verify a custom domain
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── App ───────────────────────────────────────────────────────
# Public URL of the deployed site (used in email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Open-source skill artifact ────────────────────────────────
# Public github repo URL for the one open-sourced skill (funnel_audit).
# Surfaced as a trust artifact on /sample. Falls back to a placeholder if unset.
NEXT_PUBLIC_GITHUB_OPEN_SOURCE_URL=https://github.com/skillor/funnel-audit

# ── Founder demo video (optional) ─────────────────────────────
# Loom embed URL (must start with https://www.loom.com/embed/).
# If unset, the video slot on /about renders nothing.
NEXT_PUBLIC_FOUNDER_LOOM_URL=
